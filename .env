# --- User Identity ---
HYAK_USERNAME=""  # Leave empty to default to current $USER

# --- Project Names ---
ENGINE_FOLDER_NAME="kimina-engine"
PROJECT_FOLDER_NAME="kimina_example_project"
DISCOVERY_FOLDER_NAME="kimina_server_discovery"

# --- Lean Configuration ---
LEAN_VERSION="v4.26.0"
MAX_REPL_MEM="32G"
TIMEOUT="100"

# --- SLURM Resources ---
JOB_CPUS=16
JOB_MEM="32G"
JOB_TIME="08:00:00"
JOB_ACCOUNT="stf"
JOB_PARTITION="cpu-g2"

# --- Gscratch Path Overrides ---
ELAN_HOME="/mmfs1/gscratch/scrubbed/${USER}/.elan"
PATH="/mmfs1/gscratch/scrubbed/${USER}/.elan/bin:${PATH}"